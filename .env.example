# Copy to .env for local runs. In CI these come from GitHub Secrets.

# Required for AI summarization (brief, predicted questions, bill nexus)
ANTHROPIC_API_KEY=

# Free key from https://api.congress.gov/sign-up/ . Powers nominations, bills, hearings.
CONGRESS_API_KEY=

# Optional. Defaults to claude-sonnet-4-6.
MODEL=claude-sonnet-4-6

# Set FORCE=1 to bypass the 9am-ET guard for local/manual runs.
FORCE=
